{
  "version": 2,
  "builds": [
    {
      "src": "server/index.js",
      "use": "@vercel/node"
    },
    {
      "src": "client/package.json",
      "use": "@vercel/static-build",
      "config": {
        "distDir": "build"
      }
    }
  ],
  "rewrites": [
    {
      "source": "/api/(.*)",
      "destination": "/server/index.js?path=$1"
    },
    {
      "source": "/static/(.*)",
      "destination": "/client/static/$1"
    },
    {
      "source": "/asset-manifest.json",
      "destination": "/client/asset-manifest.json"
    },
    {
      "source": "/athena.jpg",
      "destination": "/client/athena.jpg"
    },
    {
      "source": "/(.*)",
      "destination": "/client/index.html"
    }
  ],
  "env": {
    "NODE_ENV": "production"
  }
}
